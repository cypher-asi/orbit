# Orbit - Environment Configuration
#
# Copy this file to `.env` and fill in the values.
# Variables without defaults are required.
# See docs/API.md for the API contract and docs/CONFIGURATION.md for client setup (e.g. aura-app).

# PostgreSQL connection URL (required)
DATABASE_URL=postgres://user:password@localhost:5432/orbit

# Host address to bind the HTTP server to (default: 0.0.0.0)
SERVER_HOST=0.0.0.0

# Port to bind the HTTP server to (default: 3000)
SERVER_PORT=3000

# Root directory for bare Git repository storage (default: ./data/repos)
GIT_STORAGE_ROOT=./data/repos

# Logging level: trace, debug, info, warn, error (default: info)
LOG_LEVEL=info

# Comma-separated CORS allowed origins. When empty, any origin is allowed (development).
# For production (e.g. when orbit is used by aura-app), set to the frontend origin(s):
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://aura.example.com

# Optional: Redis URL for distributed rate limiting across instances.
# When unset, in-memory rate limiting is used.
# REDIS_URL=redis://127.0.0.1:6379

# Optional: Public base URL for discovery and Git clone links (e.g. for aura-app).
# When set, GET /api and GET /v1 return this as base_url and git_url_prefix.
# When unset, falls back to http://SERVER_HOST:SERVER_PORT.
# PUBLIC_BASE_URL=https://orbit.example.com
